import React, { useState } from 'react';
import { ethers } from 'ethers';

const styles = {
  container: { backgroundColor: "#0b0f19", color: "#f3f4f6", minHeight: "100vh", padding: "20px", fontFamily: "'Inter', sans-serif" },
  card: { backgroundColor: "#111827", borderRadius: "16px", padding: "24px", border: "1px solid #30363d", marginBottom: "20px" },
  // Tombol Kuning Minion
  button: { backgroundColor: "#FDC500", color: "#000", border: "none", padding: "14px", borderRadius: "12px", fontWeight: "800", cursor: "pointer", width: "100%", fontSize: "16px" },
  input: { width: "100%", padding: "15px", borderRadius: "12px", border: "1px solid #30363d", backgroundColor: "#1f2937", color: "white", marginBottom: "15px", fontSize: "16px" }
};

export default function App() {
  const [loading, setLoading] = useState(false);

  const handleSwap = async () => {
    setLoading(true);
    // Simulasi transaksi
    setTimeout(() => {
      setLoading(false);
      alert("Swap Berhasil!");
    }, 3000);
  };

  return (
    <div style={styles.container}>
      {/* HEADER dengan Logo Freesia */}
      <header style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: "40px" }}>
        <div style={{ display: "flex", alignItems: "center", gap: "12px" }}>
          <img src="/freesia-logo.png" alt="Freesia" style={{ width: "45px" }} />
          <h1 style={{ fontSize: "28px", color: "#FFD1DC", margin: 0 }}>Freesia</h1>
        </div>
        <button style={{ ...styles.button, width: "auto", padding: "10px 20px" }}>Connect</button>
      </header>

      {/* AREA UTAMA */}
      <div style={{ maxWidth: "450px", margin: "0 auto" }}>
        <div style={styles.card}>
          <h3 style={{ marginTop: 0, marginBottom: "20px" }}>Tukar Token</h3>
          <input style={styles.input} type="number" placeholder="Jumlah USDC" />
          
          <button style={styles.button} onClick={handleSwap} disabled={loading}>
            {loading ? (
              <div style={{ display: "flex", alignItems: "center", justifyContent: "center", gap: "10px" }}>
                {/* Animasi Minion Berputar */}
                <img 
                  src="https://cdn-icons-png.flaticon.com/512/5962/5962463.png" 
                  alt="loading" 
                  style={{ width: "24px", animation: "spin 2s linear infinite" }} 
                />
                Memproses...
              </div>
            ) : "Konfirmasi Swap"}
          </button>
        </div>
      </div>

      {/* Tambahkan CSS untuk animasi */}
      <style>{`
        @keyframes spin { 100% { transform: rotate(360deg); } }
      `}</style>
    </div>
  );
}
